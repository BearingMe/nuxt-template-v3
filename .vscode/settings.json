{
  "editor.formatOnSave": true,

  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "files.associations": {
    "*.css": "tailwindcss"
  },

  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "nuxt.config.*": "*.config.ts, *.config.js, *.config.mjs, *.config.cjs",
    "README.md": "*.md"
  },

  "files.exclude": {
    "**/.nuxt": true,
    "**/.git": true,
    
    ".opencode/node_modules": true,
    ".opencode/.gitignore": true,
    ".opencode/package.json": true
  },

  "search.exclude": {
    "**/.nuxt": true,
    "**/node_modules": true,
    "**/dist": true,
    "bun.lock": true
  }
}
